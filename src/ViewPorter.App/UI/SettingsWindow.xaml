<Window x:Class="ViewPorter.App.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ViewPorter"
        Width="700"
        Height="500"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock FontSize="28"
                 FontWeight="SemiBold"
                 Text="ViewPorter" />
      <TextBlock Margin="0,10,0,0"
                 Foreground="#444"
                 TextWrapping="Wrap"
                 Text="Create a smaller centered software viewport on your current monitor. Start here, then minimize to tray if you want it in the background." />
    </StackPanel>

    <Border Grid.Row="1"
            Margin="0,20,0,0"
            Padding="16"
            Background="#F5F5F5"
            CornerRadius="10">
      <StackPanel>
        <TextBlock FontWeight="SemiBold"
                   Text="Current status" />
        <TextBlock x:Name="StatusTextBlock"
                   Margin="0,8,0,0"
                   FontSize="15"
                   Text="Ready" />
        <TextBlock x:Name="ProfileTextBlock"
                   Margin="0,8,0,0"
                   Foreground="#555"
                   Text="Profile" />
      </StackPanel>
    </Border>

    <StackPanel Grid.Row="2"
                Margin="0,20,0,0"
                Orientation="Horizontal">
      <Button x:Name="EnableButton"
              Width="160"
              Height="44"
              Margin="0,0,12,0"
              Click="EnableButton_OnClick"
              Content="Enable Viewport" />
      <Button x:Name="DisableButton"
              Width="160"
              Height="44"
              Margin="0,0,12,0"
              Click="DisableButton_OnClick"
              Content="Disable Viewport" />
      <Button x:Name="MinimizeToTrayButton"
              Width="160"
              Height="44"
              Click="MinimizeToTrayButton_OnClick"
              Content="Minimize To Tray" />
    </StackPanel>

    <Grid Grid.Row="3"
          Margin="0,24,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Margin="0,0,12,0"
              Padding="16"
              BorderBrush="#DDD"
              BorderThickness="1"
              CornerRadius="10">
        <StackPanel>
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Text="How to use" />
          <TextBlock Margin="0,12,0,0"
                     TextWrapping="Wrap"
                     Text="1. Open the app and keep the window visible the first time." />
          <TextBlock Margin="0,8,0,0"
                     TextWrapping="Wrap"
                     Text="2. Bring the app or game window you want to resize to the front." />
          <TextBlock Margin="0,8,0,0"
                     TextWrapping="Wrap"
                     Text="3. Click Enable Viewport." />
          <TextBlock Margin="0,8,0,0"
                     TextWrapping="Wrap"
                     Text="4. If the result is not what you want, click Disable Viewport immediately." />
        </StackPanel>
      </Border>

      <Border Grid.Column="1"
              Margin="12,0,0,0"
              Padding="16"
              BorderBrush="#DDD"
              BorderThickness="1"
              CornerRadius="10">
        <StackPanel>
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Text="Quick controls" />
          <TextBlock Margin="0,12,0,0"
                     Text="Toggle: Ctrl+Alt+F9" />
          <TextBlock Margin="0,8,0,0"
                     Text="Emergency disable: Ctrl+Alt+F10" />
          <TextBlock Margin="0,12,0,0"
                     TextWrapping="Wrap"
                     Text="Best with normal desktop apps and borderless-windowed apps. Exclusive fullscreen is not supported." />
        </StackPanel>
      </Border>
    </Grid>

    <DockPanel Grid.Row="4"
               Margin="0,20,0,0">
      <TextBlock VerticalAlignment="Center"
                 Foreground="#666"
                 Text="The app also stays available from the tray icon." />
      <Button Width="100"
              Height="34"
              DockPanel.Dock="Right"
              Click="ExitButton_OnClick"
              Content="Exit" />
    </DockPanel>
  </Grid>
</Window>
