<Window x:Class="ViewPorter.App.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ViewPorter Settings"
        Width="520"
        Height="320"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="20">
    <StackPanel>
      <TextBlock FontSize="22"
                 FontWeight="SemiBold"
                 Text="ViewPorter" />
      <TextBlock Margin="0,12,0,0"
                 TextWrapping="Wrap"
                 Text="Initial scaffold is in place. Next implementation steps are overlay windows, foreground window movement, hotkeys, and editable profile management." />
    </StackPanel>
  </Grid>
</Window>
